{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git push --force": "deny",
      "git push --force-with-lease": "ask",
      "git reset --hard": "ask",
      "git clean -fd": "deny",
      "rm -rf *": "deny",
      "git sync": "allow",
      "git push-safe": "allow",
      "git amend": "allow",
      "git nuke-check": "allow",
      "git save": "allow",
      "git *": "ask",
      "*": "ask"
    },
    "webfetch": "ask",
    "question": "allow"
  },
  "agent": {
    "visual-helper": {
      "description": "Describes images to text only models",
      "mode": "subagent",
      "model": "openrouter/mistralai/mistral-small-3.2-24b-instruct",
      "prompt": "You are the eyes for an LLM that is text only. Describe what you see in detail."
    }
  }
}